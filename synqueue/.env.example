# ── Database ──────────────────────────────────────────────
# Neon / Supabase / Railway PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS"

# ── Pusher ─────────────────────────────────────────────────
# Create a free app at https://pusher.com — Channels product
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="mt1"

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="SynQueue"
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# ── Admin Seed ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@synqueue.com"
SEED_ADMIN_PASSWORD="Admin@123"
SEED_INSTITUTION_NAME="SynEdu University"
