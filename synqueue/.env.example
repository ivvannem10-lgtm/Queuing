# ── Database ──────────────────────────────────────────────
# Local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/synqueue"
# Railway / Supabase (replace with your connection string)
# DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS"

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SynQueue"
NODE_ENV="development"
PORT="3000"

# ── Admin Seed ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@synqueue.com"
SEED_ADMIN_PASSWORD="Admin@123"
SEED_INSTITUTION_NAME="SynEdu University"
